{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "PostJob",
  "type": "object",
  "required": ["tenantId", "positionId", "title"],
  "properties": {
    "tenantId":   { "type": "string" },
    "positionId": { "type": "string", "format": "uuid" },
    "title":      { "type": "string" },
    "closesAt":   { "type": "string", "format": "date-time" }
  }
}
