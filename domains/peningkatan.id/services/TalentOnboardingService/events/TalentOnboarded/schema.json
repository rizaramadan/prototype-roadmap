{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "TalentOnboarded",
  "type": "object",
  "required": ["talentId", "personId", "hashedNationalId", "tenantId", "positionId", "onboardedAt", "source"],
  "properties": {
    "talentId":         { "type": "string", "format": "uuid" },
    "personId":         { "type": "string", "format": "uuid" },
    "hashedNationalId": { "type": "string" },
    "tenantId":         { "type": "string" },
    "positionId":       { "type": "string", "format": "uuid" },
    "onboardedAt":      { "type": "string", "format": "date-time" },
    "source":           { "type": "string", "enum": ["recru_hired", "direct_import"] }
  }
}
