{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "PersonRegistered",
  "type": "object",
  "required": ["personId", "hashedNationalId", "registeredAt", "source"],
  "properties": {
    "personId":         { "type": "string", "format": "uuid" },
    "hashedNationalId": { "type": "string" },
    "registeredAt":     { "type": "string", "format": "date-time" },
    "source":           { "type": "string", "enum": ["www", "siswa", "beasiswa", "recru_intake", "ases_intake"] }
  }
}
