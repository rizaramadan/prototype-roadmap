{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "DefineCompetency",
  "type": "object",
  "required": ["competencyId", "name", "coreBehaviourIds"],
  "properties": {
    "competencyId":     { "type": "string", "format": "uuid" },
    "name":             { "type": "string" },
    "coreBehaviourIds": { "type": "array", "items": { "type": "string", "format": "uuid" }, "minItems": 1 },
    "description":      { "type": "string" }
  }
}
