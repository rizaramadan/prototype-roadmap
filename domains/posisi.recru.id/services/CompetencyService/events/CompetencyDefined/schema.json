{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "CompetencyDefined",
  "type": "object",
  "required": ["competencyId", "name", "coreBehaviourIds", "definedAt"],
  "properties": {
    "competencyId":     { "type": "string", "format": "uuid" },
    "name":             { "type": "string" },
    "coreBehaviourIds": { "type": "array", "items": { "type": "string", "format": "uuid" } },
    "definedAt":        { "type": "string", "format": "date-time" }
  }
}
