{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "CompetencyUpdated",
  "type": "object",
  "required": ["competencyId", "updatedAt"],
  "properties": {
    "competencyId":            { "type": "string", "format": "uuid" },
    "name":                    { "type": "string" },
    "addedCoreBehaviourIds":   { "type": "array", "items": { "type": "string", "format": "uuid" } },
    "removedCoreBehaviourIds": { "type": "array", "items": { "type": "string", "format": "uuid" } },
    "updatedAt":               { "type": "string", "format": "date-time" }
  }
}
