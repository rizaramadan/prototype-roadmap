{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "PersonCoreBehaviourProfileUpdated",
  "type": "object",
  "required": ["assessmentId", "hashedNationalId", "coreBehaviourScores", "scoredAt"],
  "properties": {
    "assessmentId":         { "type": "string", "format": "uuid" },
    "personId":             { "type": "string", "format": "uuid" },
    "hashedNationalId":     { "type": "string" },
    "coreBehaviourScores":  {
      "type": "object",
      "additionalProperties": { "type": "number", "minimum": 0, "maximum": 1 }
    },
    "positionId":   { "type": "string", "format": "uuid" },
    "fitScore":     { "type": "number", "minimum": 0, "maximum": 1 },
    "scoredAt":     { "type": "string", "format": "date-time" },
    "tenantId":     { "type": "string" }
  }
}
